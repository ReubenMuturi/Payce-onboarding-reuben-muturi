import { supabase } from '../config/supabase';
import { LoyverseClient } from '../lib/loyverse.client';
import { LoyverseItem, LoyverseCategory, LoyverseItemApi, LoyverseCategoryApi, SyncResult } from '../types/loyverse.types';
import pLimit from 'p-limit';
import { logger } from '../lib/logger';

export class LoyverseService {
    private client: LoyverseClient;

    constructor() {
        this.client = new LoyverseClient();
    }

    /**
     * Helper to retrieve an active merchant's token and sync metadata
     */
    private async getMerchantSyncInfo(merchantId: string) {
        const { data, error } = await supabase
            .from('merchants')
            .select('api_token, status, last_synced_at')
            .eq('id', merchantId)
            .single();

        if (error || !data) {
            throw new Error(`Merchant ${merchantId} not found in registry`);
        }

        if (data.status !== 'Active') {
            throw new Error(`Merchant ${merchantId} is currently ${data.status}. Access denied.`);
        }

        return {
            token: data.api_token,
            lastSyncedAt: data.last_synced_at
        };
    }

    async getAllItems(merchantId: string, updatedAt?: string): Promise<LoyverseItem[]> {
        const { token } = await this.getMerchantSyncInfo(merchantId);
        const items = await this.client.getAllItems(token, updatedAt);

        return items.map(item => ({
            ...item,
            merchant_id: merchantId
        }));
    }

    async getCategories(merchantId: string, updatedAt?: string): Promise<LoyverseCategory[]> {
        const { token } = await this.getMerchantSyncInfo(merchantId);
        const categories = await this.client.getCategories(token, updatedAt);

        return categories.map(cat => ({
            ...cat,
            merchant_id: merchantId
        }));
    }

    private async saveCategories(merchantId: string, categories: LoyverseCategory[]): Promise<void> {
        if (categories.length === 0) return;

        const categoriesData = categories.map(cat => ({
            merchant_id: merchantId,
            id: cat.id,
            name: cat.name,
            handle: cat.handle,
            sort_order: cat.sort_order,
            created_at: cat.created_at,
            updated_at: cat.updated_at,
        }));

        // Chunked Upsert
        const limit = pLimit(3);
        const chunkSize = 100;
        const chunks = Array.from({ length: Math.ceil(categoriesData.length / chunkSize) }, (_, i) =>
            categoriesData.slice(i * chunkSize, (i + 1) * chunkSize)
        );

        try {
            await Promise.all(chunks.map(chunk =>
                limit(() => supabase
                    .from('loyverse_categories')
                    .upsert(chunk, { onConflict: 'merchant_id,id' })
                )
            ));
            logger.info({ merchantId, count: categoriesData.length }, `Saved/Updated ${categoriesData.length} categories`);
        } catch (error: any) {
            logger.error({ merchantId, err: error }, 'Error saving categories to Supabase');
            throw error;
        }
    }

    private async saveItems(merchantId: string, items: LoyverseItem[]): Promise<void> {
        if (items.length === 0) return;

        const itemsData = items.map(item => ({
            merchant_id: merchantId,
            id: item.id,
            name: item.item_name,
            handle: item.handle,
            category_id: item.category_id,
            image_url: item.image_url,
            color: item.color,
            track_stock: item.track_stock || false,
            is_composite: item.is_composite || false,
            created_at: item.created_at,
            updated_at: item.updated_at,
            deleted_at: item.deleted_at,
        }));

        const variantsData = items.flatMap(item =>
            (item.variants || []).map(variant => ({
                merchant_id: merchantId,
                variant_id: variant.variant_id,
                item_id: variant.item_id,
                sku: variant.sku,
                barcode: variant.barcode,
                option1_value: variant.option1_value,
                option2_value: variant.option2_value,
                option3_value: variant.option3_value,
                default_price: variant.default_price,
                cost: variant.cost,
                created_at: variant.created_at,
                updated_at: variant.updated_at,
                deleted_at: variant.deleted_at,
            }))
        );

        const limit = pLimit(3);
        const chunkSize = 100;

        // Batch Upsert Items
        const itemChunks = Array.from({ length: Math.ceil(itemsData.length / chunkSize) }, (_, i) =>
            itemsData.slice(i * chunkSize, (i + 1) * chunkSize)
        );

        await Promise.all(itemChunks.map(chunk =>
            limit(() => supabase.from('loyverse_items').upsert(chunk, { onConflict: 'merchant_id,id' }))
        ));

        // Batch Upsert Variants
        if (variantsData.length > 0) {
            const variantChunks = Array.from({ length: Math.ceil(variantsData.length / chunkSize) }, (_, i) =>
                variantsData.slice(i * chunkSize, (i + 1) * chunkSize)
            );
            await Promise.all(variantChunks.map(chunk =>
                limit(() => supabase.from('loyverse_variants').upsert(chunk, { onConflict: 'merchant_id,variant_id' }))
            ));
        }

        logger.info({ merchantId, itemsCount: itemsData.length, variantsCount: variantsData.length }, 'Saved/Updated items and variants');
    }

    async syncSingleItem(merchantId: string, itemId: string): Promise<void> {
        try {
            const { token } = await this.getMerchantSyncInfo(merchantId);
            const itemApi = await this.client.getItem(token, itemId);

            const item: LoyverseItem = {
                ...itemApi,
                merchant_id: merchantId
            };

            await this.saveItems(merchantId, [item]);
        } catch (error: any) {
            logger.error({ merchantId, itemId, err: error.message }, 'Incremental Sync failed for item');
            throw error;
        }
    }

    async syncSingleCategory(merchantId: string, categoryId: string): Promise<void> {
        try {
            const { token } = await this.getMerchantSyncInfo(merchantId);
            const categoryApi = await this.client.getCategory(token, categoryId);

            const category: LoyverseCategory = {
                ...categoryApi,
                merchant_id: merchantId
            };

            await this.saveCategories(merchantId, [category]);
        } catch (error: any) {
            logger.error({ merchantId, categoryId, err: error.message }, 'Incremental Sync failed for category');
            throw error;
        }
    }

    async syncMenu(merchantId: string): Promise<SyncResult> {
        const { token, lastSyncedAt } = await this.getMerchantSyncInfo(merchantId);

        let updatedAt: string | undefined = undefined;
        let isFullSync = false;

        // Determine if we need a full sync:
        // 1. Never synced before
        // 2. Last sync was more than 24 hours ago
        if (!lastSyncedAt) {
            isFullSync = true;
        } else {
            const lastSyncDate = new Date(lastSyncedAt);
            const twentyFourHoursAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);
            if (lastSyncDate < twentyFourHoursAgo) {
                isFullSync = true;
            } else {
                updatedAt = lastSyncedAt;
            }
        }

        logger.info({ merchantId, mode: isFullSync ? 'FULL' : 'DELTA', updatedAt }, 'Starting Loyverse Menu Sync');

        try {
            const [items, categories] = await Promise.all([
                this.getAllItems(merchantId, updatedAt),
                this.getCategories(merchantId, updatedAt)
            ]);

            // Save categories first (FK constraint)
            await this.saveCategories(merchantId, categories);
            await this.saveItems(merchantId, items);

            // Atomic update: reset dirty flag and update last_synced_at
            const { error: syncError } = await supabase
                .from('merchants')
                .update({
                    last_synced_at: new Date().toISOString(),
                    is_dirty: false
                })
                .eq('id', merchantId);

            if (syncError) {
                logger.error({ merchantId, err: syncError }, 'Error updating sync metadata');
            }

            return {
                success: true,
                itemsCount: items.length,
                categoriesCount: categories.length,
                syncedAt: new Date().toISOString()
            };
        } catch (error: any) {
            logger.error({ merchantId, err: error.message }, 'Loyverse Sync failed');
            throw error;
        }
    }
}

export const loyverseService = new LoyverseService();
